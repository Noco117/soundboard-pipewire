#!/usr/bin/env python3
import sys
import os
import socket

def get_socket_path():
    """Dynamically locates the socket using the same logic as your C++ daemon."""
    uid = os.getuid()
    runtime_dir = f"/run/user/{uid}"
    
    if os.path.exists(runtime_dir):
        return os.path.join(runtime_dir, "soundboard.sock")
    
    # Fallback path matching your C++ logic
    home = os.environ.get("HOME")
    if home:
        return os.path.join(home, ".local/share/soundboard/soundboard.sock")
    return "/tmp/soundboard.sock"

def print_usage():
    print("Soundboard CLI Controller")
    print("Usage:")
    print("  soundboard play <path_to_wav> [volume]")
    print("  soundboard stop")
    print("  soundboard stop <path_to_wav>")
    print("  soundboard set volume <float>")
    print("  soundboard kill")
    # TODO: IMPLEMENT Soundboard link, unlink
    sys.exit(1)

def main():
    if len(sys.argv) < 2:
        print_usage()

    action = sys.argv[1].lower()
    socket_path = get_socket_path()

    # Formulate the payload string based on command arguments
    if action == "play":
        if len(sys.argv) < 3:
            print("Error: Missing file path for play command.")
            sys.exit(1)
        
        # Crucial: Resolve relative paths and '~' into absolute paths for the daemon
        raw_path = sys.argv[2]
        abs_path = os.path.abspath(os.path.expanduser(raw_path))
        if len(sys.argv) > 3:
            volume = sys.argv[3]
        payload = f"PLAY {abs_path}  {volume}"

    elif action == "stop":
        if len(sys.argv) >= 3:
            # Path-specific stop command
            raw_path = sys.argv[2]
            abs_path = os.path.abspath(os.path.expanduser(raw_path))
            payload = f"STOP {abs_path}"
        else:
            # Global master kill switch
            payload = "STOP"
    elif action == "set":
        if len(sys.argv) == 3:
            if sys.argv[2] == "volume":
                payload =  f"SET VOLUME {sys.argv[3]}"
    elif action == "kill":
        payload = "KILL"
    else:
        print(f"Error: Unknown action '{action}'")
        print_usage()

    # Transmit the payload across the local UNIX socket boundary
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
            client.connect(socket_path)
            client.sendall(payload.encode('utf-8'))
    except FileNotFoundError:
        print(f"Error: Soundboard daemon does not appear to be running (Socket not found at {socket_path}).")
        sys.exit(1)
    except ConnectionRefusedError:
        print("Error: Connection refused. Is the daemon active?")
        sys.exit(1)
    except Exception as e:
        print(f"IPC Error: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()